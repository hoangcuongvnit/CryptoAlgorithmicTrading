# ===========================================
# Binance API Configuration
# ===========================================
BINANCE_API_KEY=your_binance_api_key_here
BINANCE_API_SECRET=your_binance_api_secret_here
BINANCE_USE_TESTNET=true

# ===========================================
# Telegram Bot Configuration
# ===========================================
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
TELEGRAM_CHAT_ID=your_telegram_chat_id_here

# ===========================================
# PostgreSQL / TimescaleDB Configuration
# ===========================================
POSTGRES_USER=trader
POSTGRES_PASSWORD=strongpassword
POSTGRES_DB=cryptotrading

# ===========================================
# Trading Configuration
# ===========================================
PAPER_TRADING_MODE=true
INITIAL_BALANCE=10000.00

# ===========================================
# Risk Management Configuration
# ===========================================
MAX_DRAWDOWN_PERCENT=5.0
MIN_RISK_REWARD=2.0
MAX_POSITION_SIZE_PERCENT=2.0
COOLDOWN_SECONDS=30
RISKGUARD_REDIS_ENABLED=true
RISKGUARD_REDIS_TTL_SECONDS=86400
RISKGUARD_REDIS_SYNC_INTERVAL=60

# ===========================================
# Historical Data Backfill (optional)
# ===========================================
HISTORICAL_BACKFILL_ENABLED=false
HISTORICAL_START_DATE=2025-01-01
HISTORICAL_END_DATE=2026-03-01
