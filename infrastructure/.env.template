# ===========================================
# PostgreSQL / TimescaleDB Configuration
# ===========================================
POSTGRES_USER=trader
POSTGRES_PASSWORD=strongpassword
POSTGRES_DB=cryptotrading

# ===========================================
# MongoDB (TimelineLogger)
# ===========================================
MONGO_USERNAME=timeline_user
MONGO_PASSWORD=strongpassword
MONGO_DATABASE=cryptotrading_timeline

# ===========================================
# Trading — Risk fallback balance
# Used as VirtualAccountBalance when FinancialLedger is unreachable.
# Real balance is sourced from FinancialLedger at runtime.
# ===========================================
INITIAL_BALANCE=10000.00

# ===========================================
# Historical Data Backfill (optional)
# ===========================================
HISTORICAL_BACKFILL_ENABLED=false
HISTORICAL_START_DATE=2025-01-01
HISTORICAL_END_DATE=2026-03-01

# ===========================================
# Timeline Logger
# ===========================================
TIMELINE_BATCH_SIZE=100
TIMELINE_BATCH_TIMEOUT_MS=5000
TIMELINE_DEFAULT_RETENTION_DAYS=90

# ===========================================
# Financial Ledger
# ===========================================
FINANCIAL_LEDGER_DEFAULT_INITIAL_BALANCE=100
FINANCIAL_LEDGER_REDIS_STREAM_KEY=ledger:events
FINANCIAL_LEDGER_REDIS_CONSUMER_GROUP=financial-ledger
FINANCIAL_LEDGER_BINANCE_API_KEY=
FINANCIAL_LEDGER_BINANCE_API_SECRET=
FINANCIAL_LEDGER_BINANCE_TESTNET_API_KEY=
FINANCIAL_LEDGER_BINANCE_TESTNET_API_SECRET=
FINANCIAL_LEDGER_BINANCE_TIMEOUT_SECONDS=10
FINANCIAL_LEDGER_BINANCE_MAX_RETRIES=3
FINANCIAL_LEDGER_BINANCE_RETRY_DELAY_MS=1000

# ===========================================
# NOTE: The following settings are managed via the Settings Page UI
# and stored encrypted in the database. Do NOT configure them here.
#
#   - Binance API Key / Secret (live + testnet) + UseTestnet flag
#   - Telegram Bot Token / Chat ID
#   - Risk thresholds: MaxDrawdown, MinRiskReward, Cooldown, OrderNotional limits
#   - Strategy order sizes
#   - HouseKeeper schedule and retention policy
#
# Gateway syncs all of these to the relevant services automatically on startup.
# ===========================================
