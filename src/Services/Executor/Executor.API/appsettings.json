{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "Trading": {
    "PaperTradingMode": true,
    "GlobalKillSwitch": false,
    "AllowedSymbols": [
      "BTCUSDT",
      "ETHUSDT",
      "BNBUSDT",
      "SOLUSDT",
      "XRPUSDT"
    ],
    "MaxNotionalPerOrder": 1000,
    "PaperSlippageBps": 2,
    "Session": {
      "Enabled": true,
      "SessionHours": 4,
      "LiquidationWindowMinutes": 30,
      "SoftUnwindMinutes": 15,
      "ForcedFlattenMinutes": 10,
      "SessionTimeZone": "UTC",
      "SessionOpenCooldownSeconds": 0,
      "MaxOpenPositionsPerSession": 5
    }
  },
  "Binance": {
    "ApiKey": "",
    "ApiSecret": "",
    "UseTestnet": true
  },
  "Redis": {
    "Connection": "localhost:6379"
  },
  "ConnectionStrings": {
    "Postgres": "Host=localhost;Port=5433;Database=cryptotrading;Username=postgres;Password=postgres"
  },
  "AllowedHosts": "*",
  "Kestrel": {
    "Endpoints": {
      "gRPC": {
        "Url": "http://0.0.0.0:5014",
        "Protocols": "Http2"
      },
      "Health": {
        "Url": "http://0.0.0.0:5094",
        "Protocols": "Http1"
      }
    }
  }
}
