{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "Trading": {
    "GlobalKillSwitch": false,
    "AllowedSymbols": [
      "BTCUSDT",
      "ETHUSDT",
      "BNBUSDT",
      "SOLUSDT",
      "XRPUSDT"
    ],
    "MinOrderAmount": 5,
    "MaxNotionalPerOrder": 1000,
    "SpreadFilter": {
      "Enabled": true,
      "BtcEthSpreadLimit": 0.002,
      "AltcoinSpreadLimit": 0.005,
      "SlippageTolerance": 0.001,
      "MajorSymbols": [ "BTCUSDT", "ETHUSDT" ]
    },
    "PartialTp": {
      "Enabled": false,
      "Stage1ProfitPercent": 1.5,
      "Stage1CloseRatio": 0.5,
      "Stage2ProfitPercent": 3.0
    },
    "ConsensusPricing": {
      "Enabled": false,
      "PriceAgreementThreshold": 0.001
    },
    "Session": {
      "Enabled": true,
      "SessionHours": 8,
      "LiquidationWindowMinutes": 30,
      "SoftUnwindMinutes": 15,
      "ForcedFlattenMinutes": 2,
      "SessionTimeZone": "UTC",
      "SessionOpenCooldownSeconds": 0,
      "MaxOpenPositionsPerSession": 5
    }
  },
  "Binance": {
    "ApiKey": "",
    "ApiSecret": "",
    "UseTestnet": true
  },
  "Redis": {
    "Connection": "localhost:6379"
  },
  "ConnectionStrings": {
    "Postgres": "Host=localhost;Port=5433;Database=cryptotrading;Username=postgres;Password=postgres"
  },
  "AllowedHosts": "*",
  "Kestrel": {
    "Endpoints": {
      "gRPC": {
        "Url": "http://0.0.0.0:5014",
        "Protocols": "Http2"
      },
      "Health": {
        "Url": "http://0.0.0.0:5094",
        "Protocols": "Http1"
      }
    }
  }
}
