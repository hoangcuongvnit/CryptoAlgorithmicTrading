{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "MongoDB.Driver": "Warning"
    }
  },
  "AllowedHosts": "*",
  "Redis": {
    "Connection": "localhost:6379"
  },
  "MongoDB": {
    "ConnectionString": "mongodb://localhost:27017",
    "Database": "cryptotrading_timeline",
    "CoinEventsCollection": "coin_events",
    "EventSummaryCollection": "event_summary"
  },
  "Timeline": {
    "BatchSize": 100,
    "BatchTimeoutMs": 5000,
    "DefaultRetentionDays": 90,
    "CacheTtlMinutes": 60
  }
}
