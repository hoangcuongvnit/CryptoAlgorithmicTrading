{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.Hosting.Lifetime": "Information",
      "Ingestor.Worker": "Debug",
      "Binance.Net": "Warning"
    }
  },
  "Trading": {
