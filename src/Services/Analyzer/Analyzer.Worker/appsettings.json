{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.Hosting.Lifetime": "Information",
      "Analyzer.Worker": "Debug"
    }
  },
  "Redis": {
    "Connection": "localhost:6379"
  },
  "Analyzer": {
    "RsiPeriod": 14,
    "EmaShortPeriod": 9,
    "EmaLongPeriod": 21,
    "BbPeriod": 20,
    "BbStdDev": 2.0,
    "RsiOversoldThreshold": 35,
    "RsiOverboughtThreshold": 65,
    "BufferCapacity": 60,
    "SignalInterval": "1m"
  }
}
